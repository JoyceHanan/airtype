{
  "project_name": "AirType",
  "version": "0.1.0",
  "client": {
    "port": 3000,
    "webcam": {
      "target_fps": 30,
      "width": 640,
      "height": 480
    },
    "keyboard": {
      "default_layout": "qwerty_us",
      "visual_theme": "glassmorphism-dark"
    }
  },
  "server": {
    "port": 5000,
    "session_timeout_minutes": 60,
    "ml_service_proxy": "ws://localhost:8000/ws/stream"
  },
  "ml_service": {
    "port": 8000,
    "mediapipe": {
      "model_complexity": 1,
      "min_detection_confidence": 0.7,
      "min_tracking_confidence": 0.7
    },
    "gesture_classification": {
      "smoothing_alpha": 0.4,
      "pinch_threshold_normalized": 0.08,
      "dwell_time_threshold_ms": 500
    }
  }
}
